// 把 React.CSSProperties 轉成 CSS 文字字串（camelCase→kebab-case，數字補 px）
const styleToCss = (style: React.CSSProperties): string =>
  Object.entries(style)
    .map(([k, v]) => {
      const prop = k
        .replace(/^Webkit/, "webkit")
        .replace(/^Moz/, "moz")
        .replace(/^ms/, "ms")
        .replace(/([A-Z])/g, "-$1")
        .toLowerCase()
        .replace(/^webkit/, "-webkit")
        .replace(/^moz/, "-moz")
        .replace(/^ms/, "-ms");
      const val = typeof v === "number" ? `${v}px` : v;
      return `${prop}: ${val};`;
    })
    .join(" ");

